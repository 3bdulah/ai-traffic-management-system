# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SUMO
SUMO_HOME=/path/to/sumo
SUMO_BINARY=sumo-gui  # Use 'sumo' for headless mode

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Simulation
SIM_TICK_RATE=10  # Ticks per second for real-time playback
CV_FRAME_INTERVAL=10  # Run CV every N ticks
SUPABASE_BATCH_SIZE=50  # Ticks to batch before DB insert

# AI assistant (optional — dashboard works without it)
GROQ_API_KEY=your-groq-api-key
